<Window x:Class="CinemaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CinemaApp"
        mc:Ignorable="d"
        Title="CinemaTicket - Онлайн продажа билетов" 
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SecondaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель навигации -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryBrush}" 
                CornerRadius="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock Text="🎬" FontSize="30" Margin="0,0,10,0"/>
                    <TextBlock Text="CINEMA TICKET" 
                              Foreground="{StaticResource WhiteBrush}"
                              FontFamily="{StaticResource MainFont}"
                              FontSize="24" 
                              FontWeight="Bold"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Навигационные кнопки -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="btnMovies" 
                            Content="Фильмы" 
                            Style="{StaticResource SecondaryButton}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderBrush="{StaticResource WhiteBrush}"
                            Margin="10,0"
                            Click="btnMovies_Click"/>
                    <Button x:Name="btnSessions" 
                            Content="Сеансы" 
                            Style="{StaticResource SecondaryButton}"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderBrush="{StaticResource WhiteBrush}"
                            Margin="10,0"
                            Click="btnSessions_Click"/>
                    
                </StackPanel>

                <!-- Профиль / Вход -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserName" 
                              Text="Гость" 
                              Foreground="{StaticResource WhiteBrush}"
                              FontSize="14"
                              VerticalAlignment="Center"
                              Margin="0,0,15,0"
                              Visibility="Collapsed"/>
                    <Button x:Name="btnLogin" 
                            Content="Войти" 
                            Width="100"
                            Margin="0,0,5,0"
                            Click="btnLogin_Click"/>
                    <Button x:Name="btnRegister" 
                            Content="Регистрация" 
                            Width="110"
                            Click="btnRegister_Click"/>
                    <Button x:Name="btnProfile" 
                            Content="Профиль" 
                            Width="100"
                            Visibility="Collapsed"
                            Click="btnProfile_Click"/>
                    <Button x:Name="btnLogout" 
                            Content="Выйти" 
                            Width="80"
                            Margin="5,0,0,0"
                            Visibility="Collapsed"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Frame x:Name="MainFrame" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden"
               Background="{StaticResource SecondaryBrush}"/>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" 
                Background="{StaticResource DarkBrush}">
            <TextBlock Text="© 2026 CinemaTicket System. Все права защищены." 
                      Foreground="{StaticResource WhiteBrush}"
                      FontSize="12"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
