<Page x:Class="CinemaApp.Pages.Admin.ManageMoviesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Admin"
      mc:Ignorable="d" 
      Title="Управление фильмами"
      Background="{StaticResource SecondaryBrush}" >

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" 
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch" 
                        Style="{StaticResource CustomTextBox}"
                        TextChanged="txtSearch_TextChanged"
                        Margin="0,0,20,0"/>

                <Button x:Name="btnAdd" Grid.Column="1" 
                        Content="➕ Добавить фильм"
                        Style="{StaticResource PrimaryButton}"
                        Click="btnAdd_Click"/>
            </Grid>
        </Border>

        <!-- Список фильмов -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MoviesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" 
                                              FontSize="18" 
                                              FontWeight="Bold"
                                              Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Margin="0,5,0,0"
                                               Foreground="{StaticResource GrayBrush}">
                                        <Run Text="{Binding Duration}"/>
                                        <Run Text=" мин | "/>
                                        <Run Text="{Binding AgeRestriction}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding ReleaseYear}"/>
                                        <Run Text=" год"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" 
                                              TextWrapping="Wrap"
                                              Margin="0,5,0,0"
                                              MaxHeight="60"/>
                                </StackPanel>

                                <Button x:Name="btnEdit" Grid.Column="1" 
                                        Content="✏️ Редакт."
                                        Style="{StaticResource SecondaryButton}"
                                        Width="120"
                                        Margin="10,0"
                                        Click="btnEdit_Click"
                                        Tag="{Binding MovieID}"/>

                                <Button x:Name="btnDelete" Grid.Column="2" 
                                        Content="🗑️ Удалить"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="120"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        Click="btnDelete_Click"
                                        Tag="{Binding MovieID}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
