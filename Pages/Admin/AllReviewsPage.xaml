<Page x:Class="CinemaApp.Pages.Admin.AllReviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Admin"
      mc:Ignorable="d" 
       Title="Все отзывы"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Все отзывы пользователей" 
                  Style="{StaticResource PageTitle}"
                  Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ReviewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}">
                                    <Run Text="{Binding Movies.Title}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="1" Margin="0,5,0,0">
                                    <Run Text="👤 "/>
                                    <Run Text="{Binding Users.FullName}"/>
                                    <Run Text=" | "/>
                                    <Run Text="📅 "/>
                                    <Run Text="{Binding ReviewDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="2" Margin="0,5,0,0">
                                    <Run Text="⭐ Оценка: "/>
                                    <Run Text="{Binding Rating}"/>
                                    <Run Text="/5"/>
                                </TextBlock>

                                <TextBlock Grid.Row="3" 
                                           Text="{Binding Comment}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           Foreground="{StaticResource GrayBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
