<Page x:Class="CinemaApp.Pages.Admin.DetailedStatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Admin"
      mc:Ignorable="d" 
     Title="Детальная статистика"
      Background="{StaticResource SecondaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Детальная статистика" 
                      Style="{StaticResource PageTitle}"
                      Grid.Row="0"/>

            <!-- Выбор периода -->
            <Border Grid.Row="1" 
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Выберите период" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <DatePicker x:Name="dpStart" 
                                   Margin="0,0,10,0"
                                   Width="150"/>
                        <TextBlock Text=" - " VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpEnd" 
                                   Width="150"/>
                        <Button Content="Показать"
                                Style="{StaticResource PrimaryButton}"
                                Width="100"
                                Margin="20,0,0,0"
                                Click="Button_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Общая статистика -->
            <Border Grid.Row="2" 
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Общие показатели" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Всего бронирований:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="txtTotalBookings"/>

                        <TextBlock Grid.Row="1" Text="Оплаченных:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPaidBookings" Margin="0,5,0,0"/>

                        <TextBlock Grid.Row="2" Text="Отмененных:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtCancelledBookings" Margin="0,5,0,0"/>

                        <TextBlock Grid.Row="3" Text="Общая выручка:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtTotalRevenue" 
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="Bold"
                                   Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="4" Text="Средний чек:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtAverageCheck" Margin="0,5,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Статистика по фильмам -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <StackPanel Margin="10">
                    <TextBlock Text="Статистика по фильмам" 
                              FontSize="16" 
                              FontWeight="Bold"
                              Margin="0,0,0,10"/>

                    <ItemsControl x:Name="MoviesStatsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource LightBrush}" 
                                        BorderThickness="0,0,0,1"
                                        Margin="0,5">
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding BookingsCount}" 
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Revenue, StringFormat={}{0:F2} руб}" 
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
