<Page x:Class="CinemaApp.Pages.Admin.ManageEmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Admin"
      mc:Ignorable="d" 
      Title="Управление сотрудниками"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление сотрудниками" 
                  Style="{StaticResource PageTitle}"
                  Grid.Row="0"/>

        <!-- Панель добавления -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">
            <StackPanel Margin="10">
                <TextBlock Text="Добавить нового сотрудника" 
                          FontSize="16" 
                          FontWeight="Bold"
                          Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин" Margin="5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Пароль" Margin="5"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="ФИО" Margin="5"/>

                    <TextBox x:Name="txtLogin" 
                             Grid.Row="1" Grid.Column="0"
                             Margin="5" Width="100"
                             Style="{StaticResource CustomTextBox}"/>

                    <PasswordBox x:Name="txtPassword" 
                                 Grid.Row="1" Grid.Column="1"
                                 Margin="5" Width="100"
                                 />

                    <TextBox x:Name="txtFullName" 
                             Grid.Row="1" Grid.Column="2"
                             Margin="5" Width="100"
                             Style="{StaticResource CustomTextBox}"/>

                    <Button x:Name="btnAddEmployee" Grid.Row="1" Grid.Column="3"
                            Content="➕ Добавить"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Margin="5"
                            Click="btnAddEmployee_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Список сотрудников -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EmployeesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}">
                                        <Run Text="{Binding FullName}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,5,0,0">
                                        <Run Text="👤 Логин: "/>
                                        <Run Text="{Binding Login}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="📧 Email: "/>
                                        <Run Text="{Binding Email}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="📞 Телефон: "/>
                                        <Run Text="{Binding Phone}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Button x:Name="btnResetPassword" Grid.Column="1" 
                                        Content="🔑 Сброс пароля"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="160"
                                        Margin="10,0"
                                        Click="btnResetPassword_Click"
                                        Tag="{Binding UserID}"/>

                                <Button x:Name="btnDeleteEmployee" Grid.Column="2" 
                                        Content="🗑️ Удалить"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="120"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        Click="btnDeleteEmployee_Click"
                                        Tag="{Binding UserID}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
