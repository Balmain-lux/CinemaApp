<Page x:Class="CinemaApp.Pages.Common.BookingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Common"
      mc:Ignorable="d" 
      Title="Бронирование мест"
      Background="{StaticResource SecondaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                      Text="Выбор мест" 
                      Style="{StaticResource PageTitle}"/>

            <!-- Информация о сеансе -->
            <Border Grid.Row="1" 
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtSessionInfo" 
                              FontSize="16" 
                              FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtSelectedSeats" 
                              Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Схема зала -->
            <Border Grid.Row="2" 
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Экран" 
                              FontSize="20" 
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20"
                              Foreground="{StaticResource GrayBrush}"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        <Grid x:Name="SeatsGrid">
                            <!-- Места будут добавлены динамически -->
                        </Grid>
                    </ScrollViewer>

                    <!-- Легенда -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <Rectangle Width="20" Height="20" Fill="#E0E0E0" Margin="0,0,10,0"/>
                            <TextBlock Text="Занято"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <Rectangle Width="20" Height="20" Fill="{StaticResource PrimaryBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="Выбрано"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="20" Height="20" Fill="{StaticResource GrayBrush}" Margin="0,0,10,0"/>
                            <TextBlock Text="Свободно"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                
                <TextBlock x:Name="txtTotalPrice" 
                          FontSize="18" 
                          FontWeight="Bold"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0"/>
                <Button x:Name="btnConfirm" 
                        Content="Подтвердить бронирование"
                        Style="{StaticResource PrimaryButton}"
                        Width="250"
                        Click="btnConfirm_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
