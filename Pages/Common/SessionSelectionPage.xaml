<Page x:Class="CinemaApp.Pages.Common.SessionSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Common"
      mc:Ignorable="d" 
     Title="Выбор сеанса"
      Background="{StaticResource SecondaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                      Text="Выбор сеанса" 
                      Style="{StaticResource PageTitle}"/>

            <!-- Выбор даты -->
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        Margin="0,0,0,20">
                <TextBlock Text="Дата: " 
                          FontSize="16" 
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <DatePicker x:Name="datePicker" 
                           SelectedDateChanged="datePicker_SelectedDateChanged"
                           Width="200"/>
            </StackPanel>

            <!-- Информация о фильме (если выбран конкретный) -->
            <Border Grid.Row="2" 
                    x:Name="MovieInfoPanel" 
                    Visibility="Collapsed"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="txtMovieTitle" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock x:Name="txtMovieDesc" 
                              TextWrapping="Wrap"
                              Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Список сеансов -->
            <StackPanel x:Name="SessionsPanel" Grid.Row="3"/>
        </Grid>
    </ScrollViewer>
</Page>
