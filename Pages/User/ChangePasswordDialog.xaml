<Window x:Class="CinemaApp.Pages.User.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CinemaApp.Pages.User"
        mc:Ignorable="d"
        Title="Смена пароля"
        Width="400" 
        Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SecondaryBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Смена пароля" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Текущий пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtOldPassword" 
                     Grid.Row="2"
                    
                     Height="35"
                     Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Новый пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtNewPassword" 
                     Grid.Row="4"
                     
                     Height="35"
                     Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="Подтверждение пароля" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtConfirmPassword" 
                     Grid.Row="6"
                    
                     Height="35"
                     Margin="0,0,0,20"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Content="Отмена" 
                    Style="{StaticResource SecondaryButton}"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="btnCancel_Click"/>
            <Button x:Name="btnSave" Content="Сохранить" 
                    Style="{StaticResource PrimaryButton}"
                    Width="120"
                    Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
