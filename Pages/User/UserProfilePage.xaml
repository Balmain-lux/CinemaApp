<Page x:Class="CinemaApp.Pages.User.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.User"
      mc:Ignorable="d" 
     Title="Мой профиль"
      Background="{StaticResource SecondaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                  Text="Мой профиль" 
                  Style="{StaticResource PageTitle}"/>

        <!-- Информация о пользователе -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="ФИО:" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" 
                           x:Name="txtFullName"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Логин:" 
                           FontWeight="Bold"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" 
                           x:Name="txtLogin"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Email:" 
                           FontWeight="Bold"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         x:Name="txtEmail"
                         Margin="0,10,0,0"
                         Height="35"/>

                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Телефон:" 
                           FontWeight="Bold"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         x:Name="txtPhone"
                         Margin="0,10,0,0"
                         Height="35"/>

                <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="Дата регистрации:" 
                           FontWeight="Bold"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="4" Grid.Column="1" 
                           x:Name="txtRegDate"
                           Margin="0,10,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource GrayBrush}"/>

                <StackPanel Grid.Row="5" Grid.Column="1" 
                            Orientation="Horizontal"
                            Margin="0,20,0,0">
                    <Button x:Name="btnSave" Content="Сохранить изменения"
                            Style="{StaticResource PrimaryButton}"
                            Width="180"
                            Click="btnSave_Click"/>
                    <Button x:Name="btnChangePassword" Content="Сменить пароль"
                            Style="{StaticResource SecondaryButton}"
                            Width="150"
                            Margin="10,0,0,0"
                            Click="btnChangePassword_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Статистика пользователя -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                           Text="Моя статистика" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- Всего бронирований -->
                <Border Grid.Row="1" Grid.Column="0" 
                        Style="{StaticResource CardBorder}"
                        Margin="0,0,10,0"
                        Background="{StaticResource LightBrush}">
                    <StackPanel Margin="15">
                        <TextBlock Text="🎫" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalBookings" 
                                   Text="0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Всего бронирований" 
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource GrayBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Потрачено -->
                <Border Grid.Row="1" Grid.Column="1" 
                        Style="{StaticResource CardBorder}"
                        Margin="5,0,5,0"
                        Background="{StaticResource LightBrush}">
                    <StackPanel Margin="15">
                        <TextBlock Text="💰" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalSpent" 
                                   Text="0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Потрачено (руб)" 
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource GrayBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Отзывов -->
                <Border Grid.Row="1" Grid.Column="2" 
                        Style="{StaticResource CardBorder}"
                        Margin="10,0,0,0"
                        Background="{StaticResource LightBrush}">
                    <StackPanel Margin="15">
                        <TextBlock Text="⭐" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalReviews" 
                                   Text="0" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Написано отзывов" 
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource GrayBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>

</Page>
