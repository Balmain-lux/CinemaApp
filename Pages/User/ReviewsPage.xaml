<Page x:Class="CinemaApp.Pages.User.ReviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.User"
      mc:Ignorable="d" 
      Title="Мои отзывы"
      Background="{StaticResource SecondaryBrush}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                  Text="Мои отзывы" 
                  Style="{StaticResource PageTitle}"/>

        <!-- Кнопка добавления нового отзыва -->
        <Button x:Name="btnAddReview" Grid.Row="1" 
                Content="➕ Добавить отзыв"
                Style="{StaticResource PrimaryButton}"
                Width="200"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"
                Click="btnAddReview_Click"/>

        <!-- Список отзывов -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ReviewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Название фильма -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           FontSize="18" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}">
                                    <Run Text="{Binding Movies.Title}"/>
                                </TextBlock>

                                <!-- Дата отзыва -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Foreground="{StaticResource GrayBrush}"
                                           FontSize="12">
                                    <Run Text="{Binding ReviewDate, StringFormat=dd.MM.yyyy}"/>
                                </TextBlock>

                                <!-- Звезды рейтинга -->
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           FontSize="16"
                                           Margin="0,5,0,5">
                                    <Run Text="⭐ "/>
                                    <Run Text="{Binding Rating}"/>
                                    <Run Text="/5"/>
                                </TextBlock>

                                <!-- Комментарий -->
                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="{Binding Comment}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <!-- Кнопки действий -->
                                <StackPanel Grid.Row="3" Grid.Column="0" 
                                            Orientation="Horizontal">
                                    <Button x:Name="btnEditReview" Content="Редактировать"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="120"
                                            Height="45"
                                            Margin="0,0,10,0"
                                            Click="btnEditReview_Click"
                                            Tag="{Binding ReviewID}"/>
                                    <Button x:Name="btnDeleteReview" Content="Удалить"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="100"
                                            Height="45"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            BorderBrush="{StaticResource PrimaryBrush}"
                                            Click="btnDeleteReview_Click"
                                            Tag="{Binding ReviewID}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
