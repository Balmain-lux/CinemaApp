<Page x:Class="CinemaApp.Pages.User.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.User"
      mc:Ignorable="d" 
     Title="Оплата"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                  Text="Оплата билетов" 
                  Style="{StaticResource PageTitle}"/>

        <!-- Детали заказа -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock x:Name="txtOrderDetails" 
                          FontSize="16" 
                          Margin="0,0,0,20"/>

                <TextBlock Text="Выберите способ оплаты:" 
                          FontSize="16" 
                          FontWeight="SemiBold"
                          Margin="0,0,0,15"/>

                <ComboBox x:Name="cmbPaymentMethod" 
                         Width="300" 
                         Height="40"
                         HorizontalAlignment="Left"/>

                <!-- Форма для карты -->
                <Border x:Name="CardPaymentPanel" 
                        Visibility="Collapsed"
                        Margin="0,20,0,0"
                        Padding="20"
                        CornerRadius="5"
                        BorderBrush="{StaticResource GrayBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Номер карты:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCardNumber" 
                                Style="{StaticResource CustomTextBox}"
                                Width="300"
                                Margin="0,0,0,15"/>

                        <Grid Width="300">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="MM/ГГ" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtExpiry" 
                                        Style="{StaticResource CustomTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="CVV" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCVV" 
                                        Style="{StaticResource CustomTextBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="txtTotalAmount" 
                          FontSize="20" 
                          FontWeight="Bold"
                          Foreground="{StaticResource PrimaryBrush}"
                          Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="btnBack" Content="Назад" 
                    Style="{StaticResource SecondaryButton}"
                    Width="120"
                    Margin="0,0,10,0"
                    Click="btnBack_Click"/>
            <Button x:Name="btnPay" 
                    Content="Оплатить"
                    Style="{StaticResource PrimaryButton}"
                    Width="200"
                    Click="btnPay_Click"/>
        </StackPanel>
    </Grid>
</Page>
