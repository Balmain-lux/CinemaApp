<Page x:Class="CinemaApp.Pages.Guest.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Guest"
      mc:Ignorable="d" 
      Title="Авторизация"
      Background="{StaticResource SecondaryBrush}">

    <Grid>
        <Border Width="400" 
                MaxHeight="650"
                Style="{StaticResource CardBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock x:Name="txtTitle" 
                          Text="Вход в систему" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="{StaticResource PrimaryBrush}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,30"/>

                <TextBlock Text="Логин" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="40"
                        
                        Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                            Margin="0,0,0,15" Height="40"/>

                <!-- Поля для регистрации -->
                <TextBlock x:Name="lblFullName" 
                          Text="Полное имя" 
                          Margin="0,0,0,5"
                          Visibility="Collapsed"/>
                <TextBox x:Name="txtFullName" 
                       
                        Margin="0,0,0,15"
                        Visibility="Collapsed"/>

                <TextBlock x:Name="lblEmail" 
                          Text="Email" 
                          Margin="0,0,0,5"
                          Visibility="Collapsed"/>
                <TextBox x:Name="txtEmail" 
                        
                        Margin="0,0,0,15"
                        Visibility="Collapsed"/>

                <TextBlock x:Name="lblPhone" 
                          Text="Телефон" 
                          Margin="0,0,0,5"
                          Visibility="Collapsed"/>
                <TextBox x:Name="txtPhone" 
                        
                        Margin="0,0,0,15"
                        Visibility="Collapsed"/>

                <Button x:Name="btnAction" 
                        Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,20,0,15"
                        Click="btnAction_Click"/>

                <Button x:Name="btnSwitch" 
                        Content="Нет аккаунта? Зарегистрироваться"
                        Style="{StaticResource SecondaryButton}"
                        Click="btnSwitch_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
