<Page x:Class="CinemaApp.Pages.Guest.GuestSessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Guest"
      mc:Ignorable="d" 
     Title="Сеансы"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                  x:Name="txtTitle"
                  Text="Доступные сеансы" 
                  Style="{StaticResource PageTitle}"/>

        <!-- Приглашение к регистрации -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}"
                Background="{StaticResource LightBrush}"
                Margin="0,0,0,20">
            <StackPanel Margin="15" Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="24" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="Только для зарегистрированных пользователей!"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Чтобы забронировать билеты, необходимо авторизоваться."
                               FontSize="12"
                               Foreground="{StaticResource GrayBrush}"/>
                </StackPanel>
                <Button x:Name="btnLogin" Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Width="100"
                        Height="45"
                        VerticalAlignment="Center"
                        Margin="15,0,0,0"
                        Click="btnLogin_Click"/>
                <Button x:Name="btnRegister" Content="Регистрация"
                        Style="{StaticResource SecondaryButton}"
                        Width="140"
                        Height="45"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        Click="btnRegister_Click"/>
            </StackPanel>
        </Border>

        <!-- Выбор даты -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">
            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock Text="Дата:" 
                          FontSize="14" 
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>
                <DatePicker x:Name="datePicker" 
                           SelectedDateChanged="datePicker_SelectedDateChanged"
                           Width="150"/>
            </StackPanel>
        </Border>

        <!-- Список сеансов -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SessionsList" >
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid Margin="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="MovieTitle" Mode="OneWay"/>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <TextBlock Margin="0,5,0,0">
                                <Run Text="⏰ "/>
                                <Run Text="{Binding Time, Mode=OneWay}"/>
                                <Run Text=" | 🏢 "/>
                                <Run Text="{Binding HallName, Mode=OneWay}"/>
                                <Run Text=" | 💺 "/>
                                <Run Text="{Binding FreeSeats, Mode=OneWay}"/>
                                <Run Text=" свободно"/>
                                    </TextBlock>

                                    <TextBlock FontWeight="Bold" Margin="0,5,0,0">
                                <Run Text="💰 "/>
                                <Run Text="{Binding Price, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                <Run Text=" руб."/>
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                Content="Забронировать"
                                Style="{StaticResource PrimaryButton}"
                                Width="140"
                                Height="40"
                                VerticalAlignment="Center"
                                IsEnabled="False"
                                Opacity="0.6">
                                    <Button.ToolTip>
                                        <TextBlock>Доступно только после входа</TextBlock>
                                    </Button.ToolTip>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
