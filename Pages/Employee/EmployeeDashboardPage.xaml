<Page x:Class="CinemaApp.Pages.Employee.EmployeeDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaApp.Pages.Employee"
      mc:Ignorable="d" 
     Title="Панель сотрудника"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Панель сотрудника" 
                  Style="{StaticResource PageTitle}"
                  Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню -->
            <Border Grid.Column="0" 
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,10,0">
                <StackPanel>
                    <Button x:Name="btnMyShifts" Content="📅 Мои смены"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Click="btnMyShifts_Click"/>
                    <Button x:Name="btnSellTickets" Content="🎫 Продажа билетов"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Click="btnSellTickets_Click"/>
                    <Button x:Name="btnHallStats" Content="📊 Статистика зала"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Click="btnHallStats_Click"/>
                </StackPanel>
            </Border>

            <!-- Контент -->
            <Frame x:Name="EmployeeContentFrame" 
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Page>
