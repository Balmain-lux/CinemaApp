<Page x:Class="CinemaApp.Pages.Employee.HallStatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:local="clr-namespace:CinemaApp.Pages.Employee"
      mc:Ignorable="d" 
     Title="Статистика зала"
      Background="{StaticResource SecondaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Статистика зала" 
                  Style="{StaticResource PageTitle}"
                  Grid.Row="0"/>

        <!-- Выбор зала и даты -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,20">
            <StackPanel Margin="10" Orientation="Horizontal">
                <ComboBox x:Name="cmbHall" 
                          Width="150"
                          Height="35"
                          DisplayMemberPath="HallName"
                          SelectedValuePath="HallID"
                          Margin="0,0,10,0"
                          SelectionChanged="cmbHall_SelectionChanged"/>

                <DatePicker x:Name="dpDate" 
                            Width="120"
                            SelectedDateChanged="dpDate_SelectedDateChanged"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Сеансы -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Сеансы на выбранную дату" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"/>
                        <ItemsControl x:Name="SessionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource LightBrush}" 
                                            BorderThickness="0,0,0,1"
                                            Padding="5">
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:HH:mm}">
                                                        <Binding Path="SessionDateTime"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>

                                            <TextBlock Grid.Column="1" Text="{Binding Movies.Title, Mode=OneWay}"/>

                                            <TextBlock Grid.Column="2" 
                                                       Foreground="{StaticResource GrayBrush}"
                                                       HorizontalAlignment="Right">
                                                <Run Text="Продано: "/>
                                                <Run Text="{Binding BookingsCount, Mode=OneWay, FallbackValue=0}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Популярные фильмы -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel Margin="10">
                        <TextBlock Text="Популярные фильмы" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"/>
                        <ItemsControl x:Name="PopularMoviesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource LightBrush}" 
                                            BorderThickness="0,0,0,1"
                                            Padding="5">
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" 
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right">
                                                <Run Text="{Binding BookingsCount, Mode=OneWay}"/>
                                                <Run Text=" бил."/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
